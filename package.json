{
  "name": "@tardiq/dev-config",
  "version": "0.1.0-alpha.1",
  "description": "Shared linting, formatting, and editor configuration for all Tardiq packages",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    "./eslint/base": "./eslint/base.js",
    "./eslint/node": "./eslint/node.js",
    "./eslint/vue": "./eslint/vue.js",
    "./prettier": "./prettier/index.js",
    "./tsconfig/base.json": "./tsconfig/base.json",
    "./tsconfig/node.json": "./tsconfig/node.json",
    "./tsconfig/vue.json": "./tsconfig/vue.json",
    "./commitlint": "./commitlint/index.js"
  },
  "files": [
    "eslint/",
    "prettier/",
    "tsconfig/",
    "commitlint/",
    ".vscode/",
    "prettier.config.js",
    "commitlint.config.js",
    "README.md"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tardiq/tardiq-dev-config.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "peerDependencies": {
    "@commitlint/cli": "^20.0.0",
    "eslint": "^10.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0 || ^6.0.0"
  },
  "peerDependenciesMeta": {
    "@commitlint/cli": {
      "optional": true
    }
  },
  "dependencies": {
    "@commitlint/config-conventional": "^20.5.0",
    "eslint-plugin-vue": "^10.8.0",
    "typescript-eslint": "^8.58.0",
    "vue-eslint-parser": "^10.4.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2"
  }
}
